// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Company {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  domain      String?  // Their real/original website
  generatedDomain String? // Our generated .minicon.eu site
  industry    String?
  address     String?
  contactEmail String?
  
  // Legal details
  managingDirector String? // Geschäftsführer
  registerEntry    String? // Handelsregister
  vatId            String? // USt-IdNr.
  
  hasOwnWebsite Boolean @default(false) // true if they have a real website

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  analyses    WebsiteAnalysis[]
  deployments Deployment[]
}

model WebsiteAnalysis {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId   String   @db.ObjectId
  company     Company  @relation(fields: [companyId], references: [id])
  
  status      String   // e.g., "pending", "analyzing", "completed", "failed"
  score       Int?
  issues      String?  // JSON string or comma-separated list
  
  legalCheckStatus String @default("pending") // "pending", "passed", "failed"
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Deployment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId   String   @db.ObjectId
  company     Company  @relation(fields: [companyId], references: [id])
  
  status      String   // "queued", "deploying", "live", "failed"
  liveUrl     String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AgentActivity {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  agentName String
  summary   String
  createdAt DateTime @default(now())
}
